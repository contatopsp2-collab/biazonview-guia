tin */\n@font-face {\n  font-family: 'JetBrains Mono';\n  font-style: normal;\n  font-weight: 700;\n  font-display: swap;\n  src: url(\"2bf3df04-1a5d-4d64-a40e-d8e7e6485e4b\") format('woff2');\n  unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;\n}\n<\u002Fstyle>\n<style>\n  :root{\n    --blue:#0066CC; --blue-600:#0a5bd6; --blue-700:#0b48a0;\n    --teal:#00B4D8; --teal-deep:#0a85ab;\n    --mgr:#7c3aed; --mgr-soft:#efe9fe;\n    --ink:#0f1830; --ink-2:#1d263e; --muted:#5b6478; --muted-2:#828aa0;\n    --bg:#eaf0fb; --card:#ffffff; --line:#e3e8f2; --line-2:#d4dce9;\n    --r:18px; --r-lg:26px;\n    --shadow:0 18px 48px -22px rgba(16,32,84,.30);\n    --shadow-sm:0 8px 22px -12px rgba(16,32,84,.22);\n    --maxw:1180px;\n  }\n  *{box-sizing:border-box;margin:0;padding:0}\n  html{scroll-behavior:smooth}\n  body{\n    font-family:'Inter',system-ui,sans-serif;\n    color:var(--ink);\n    background:\n      radial-gradient(1100px 700px at 88% -8%, rgba(0,180,216,.10), transparent 60%),\n      radial-gradient(900px 600px at 6% 4%, rgba(0,102,204,.10), transparent 55%),\n      linear-gradient(180deg,#eef3fc 0%, #e7eef9 100%);\n    background-attachment:fixed;\n    -webkit-font-smoothing:antialiased;\n    line-height:1.5;\n  }\n  img,svg{display:block;max-width:100%}\n  a{color:var(--blue);text-decoration:none}\n  .mono{font-family:'JetBrains Mono',ui-monospace,monospace}\n  .wrap{max-width:var(--maxw);margin:0 auto;padding:0 24px}\n\n  /* ---------------- top bar ---------------- */\n  .topbar{\n    position:sticky;top:0;z-index:40;\n    background:rgba(255,255,255,.78);\n    backdrop-filter:blur(14px);\n    border-bottom:1px solid var(--line);\n  }\n  .topbar-in{display:flex;align-items:center;justify-content:space-between;height:64px;gap:16px}\n  .brand{display:flex;align-items:center;gap:11px}\n  .brand .mark{width:30px;height:30px;flex:0 0 30px}\n  .brand .bt{font-weight:800;letter-spacing:.01em;font-size:16px;line-height:1.05}\n  .brand .bt small{display:block;font-weight:500;font-size:9.5px;letter-spacing:.26em;color:var(--muted);text-transform:uppercase}\n  .top-pill{\n    font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;\n    color:var(--blue);background:rgba(0,102,204,.08);border:1px solid rgba(0,102,204,.2);\n    padding:7px 13px;border-radius:99px;\n  }\n\n  /* ---------------- hero ---------------- */\n  .hero{padding:62px 0 30px;text-align:center}\n  .kicker{\n    display:inline-flex;align-items:center;gap:9px;\n    font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:600;letter-spacing:.2em;text-transform:uppercase;\n    color:var(--teal-deep);background:rgba(0,180,216,.1);border:1px solid rgba(0,180,216,.26);\n    padding:7px 15px;border-radius:99px;\n  }\n  .kicker .dot{width:7px;height:7px;border-radius:50%;background:var(--teal);box-shadow:0 0 0 4px rgba(0,180,216,.18)}\n  .hero h1{\n    font-size:clamp(34px,5.4vw,56px);font-weight:800;letter-spacing:-.025em;line-height:1.04;\n    margin:22px auto 0;max-width:14ch;\n  }\n  .hero h1 em{font-style:normal;color:var(--blue);position:relative;white-space:nowrap}\n  .hero p.sub{\n    margin:20px auto 0;max-width:62ch;font-size:clamp(15px,1.7vw,18px);color:var(--muted);text-wrap:pretty;\n  }\n  .hero-meta{display:flex;gap:10px;flex-wrap:wrap;justify-content:center;margin-top:26px}\n  .hm{\n    display:inline-flex;align-items:center;gap:8px;font-size:13px;font-weight:600;color:var(--ink-2);\n    background:#fff;border:1px solid var(--line);padding:9px 15px;border-radius:99px;box-shadow:var(--shadow-sm);\n  }\n  .hm svg{width:15px;height:15px;color:var(--blue)}\n\n  /* ---------------- legend ---------------- */\n  .legend{\n    margin:38px auto 0;max-width:760px;\n    display:grid;grid-template-columns:repeat(3,1fr);gap:12px;\n  }\n  .lg-card{\n    background:#fff;border:1px solid var(--line);border-radius:16px;padding:15px 16px;\n    display:flex;gap:12px;align-items:flex-start;box-shadow:var(--shadow-sm);\n  }\n  .lg-dot{width:30px;height:30px;border-radius:9px;flex:0 0 30px;display:flex;align-items:center;justify-content:center}\n  .lg-dot svg{width:17px;height:17px;color:#fff}\n  .lg-card .t{font-weight:700;font-size:13.5px;letter-spacing:.02em}\n  .lg-card .d{font-size:12px;color:var(--muted);margin-top:2px;line-height:1.4}\n  .lg-card.user .lg-dot{background:var(--blue)}\n  .lg-card.sys .lg-dot{background:var(--teal-deep)}\n  .lg-card.mgr .lg-dot{background:var(--mgr)}\n\n  /* ---------------- index chips ---------------- */\n  .toc{display:flex;flex-wrap:wrap;gap:9px;justify-content:center;margin:40px auto 0;max-width:900px}\n  .toc a{\n    font-size:12.5px;font-weight:600;color:var(--ink-2);\n    background:#fff;border:1px solid var(--line-2);padding:8px 14px;border-radius:99px;\n    display:inline-flex;align-items:center;gap:8px;transition:.18s;\n  }\n  .toc a .n{font-family:'JetBrains Mono',monospace;color:var(--blue);font-weight:700}\n  .toc a:hover{border-color:var(--blue);box-shadow:0 6px 16px -8px rgba(0,102,204,.4);transform:translateY(-1px)}\n\n  /* ---------------- section / step ---------------- */\n  .step{padding:54px 0 8px;position:relative}\n  .step + .step{border-top:1px dashed var(--line-2)}\n  .step-head{max-width:760px;margin:0 auto 30px}\n  .step-kicker{display:flex;align-items:center;gap:13px;margin-bottom:14px}\n  .step-no{\n    width:46px;height:46px;flex:0 0 46px;border-radius:13px;\n    background:linear-gradient(150deg,var(--blue),#0a3f8f);color:#fff;\n    font-family:'JetBrains Mono',monospace;font-weight:700;font-size:18px;\n    display:flex;align-items:center;justify-content:center;\n    box-shadow:0 12px 26px -10px rgba(0,72,160,.6);\n  }\n  .step-tag{\n    font-family:'JetBrains Mono',monospace;font-size:11.5px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;\n    color:var(--t